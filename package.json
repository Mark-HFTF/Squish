{
  "name": "squish",
  "version": "0.1.0",
  "private": true,
  "description": "Native desktop batch transcoder for MP4 and WebM outputs.",
  "author": "Hi from the Future",
  "main": "electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "app": "npm run build && electron .",
    "dist:win": "npm run build && electron-builder --win portable --publish never",
    "preview": "vite preview",
    "test": "vitest run"
  },
  "dependencies": {
    "@fontsource/ibm-plex-mono": "^5.2.7"
  },
  "devDependencies": {
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1",
    "vite": "^5.4.11",
    "vitest": "^2.1.5"
  },
  "build": {
    "appId": "com.hftf.squish",
    "productName": "Squish",
    "directories": {
      "output": "release-portable"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "src/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Squish-${version}-win-${arch}.${ext}"
    }
  }
}
